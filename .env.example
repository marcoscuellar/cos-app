# COS environment variables.
#
# These are consumed ONLY by the serverless functions in /api — never by the
# Vite client bundle. Do not prefix any of them with VITE_ (that would expose
# them to the browser). Locally, pull the real values from Vercel with:
#
#   vercel link        # once, to connect this dir to the Vercel project
#   npm run pull-env   # writes .env.local from the project's env vars
#
# On Vercel these are already configured on the project, so deployments need no
# extra setup.

# Anthropic — powers the Brainstorm panel (/api/brainstorm)
ANTHROPIC_API_KEY=

# Vercel KV — persists UI state (/api/state)
KV_REST_API_URL=
KV_REST_API_TOKEN=
