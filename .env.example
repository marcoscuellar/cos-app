# COS environment variables.
#
# These are consumed ONLY by the serverless functions in /api — never by the
# Vite client bundle. Do not prefix any of them with VITE_ (that would expose
# them to the browser). Locally, pull the real values from Vercel with:
#
#   vercel link        # once, to connect this dir to the Vercel project
#   npm run pull-env   # writes .env.local from the project's env vars
#
# On Vercel these are already configured on the project, so deployments need no
# extra setup.

# Anthropic — powers the Brainstorm panel (/api/brainstorm)
ANTHROPIC_API_KEY=

# Vercel KV — persists UI state (/api/state) and the test-login first-use clock
KV_REST_API_URL=
KV_REST_API_TOKEN=

# User management (/api/login, /api/auth, /api/users, /api/invite)
# Who is the admin (can access /admin/users):
APP_ADMIN_EMAIL=marcosmcuellar@gmail.com
# One-time bootstrap password for the admin's first login (seeds the KV user
# record, hashed with bcrypt). Can be rotated/removed after first sign-in.
APP_ADMIN_PASSWORD=
# Secret used to sign session tokens (HMAC-SHA256). Use a long random string,
# e.g. `openssl rand -base64 32`. Required for login sessions + the admin page.
AUTH_SECRET=

# Optional — overrides the time-limited test account's password (/api/login).
# Defaults to the provisioned password if unset.
TEST_LOGIN_PASSWORD=
